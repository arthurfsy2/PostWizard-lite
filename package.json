{
  "name": "PostWizard-lite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:uat": "next dev --port 3001",
    "build": "NEXT_PUBLIC_GIT_HASH=$(git rev-parse --short HEAD) next build",
    "build:local": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "log-monitor": "tsx scripts/log-monitor.ts",
    "cron:dev": "tsx scripts/cron-tasks.ts",
    "check:tech-debt": "node scripts/tech-debt-checker.js",
    "check:tech-debt:fix": "node scripts/tech-debt-checker.js --fix",
    "check:tech-debt:schedule": "node scripts/tech-debt-checker.js --auto-schedule",
    "tech-debt:apply": "node scripts/tech-debt-checker.js --apply-fixes",
    "tech-debt:tasks": "node scripts/tech-debt-checker.js --list-tasks",
    "check:local-user": "node scripts/local-user-check.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "auth:check": "node scripts/auth-cleanup.js --dry-run",
    "auth:cleanup": "node scripts/auth-cleanup.js",
    "db:migrate": "prisma migrate dev",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.95.2",
    "@types/leaflet": "^1.9.21",
    "@uiw/react-md-editor": "^4.0.11",
    "@vercel/blob": "^2.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "d3-cloud": "^1.2.9",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "imap": "^0.8.19",
    "imapflow": "^1.3.1",
    "isomorphic-dompurify": "^3.7.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "mailparser": "^3.9.6",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.7",
    "openai": "^6.33.0",
    "opencc-js": "^1.0.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.0.2",
    "tesseract.js": "^7.0.0",
    "wordcloud": "^1.2.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/imap": "^0.8.43",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^26.1.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
